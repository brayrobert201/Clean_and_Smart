[
  {
    "type": "heading",
    "defaultValue": "Bob's Transport Settings"
  },
  {
    "type": "section",
    "items": [
      { "type": "heading", "defaultValue": "Time & Date" },
      {
        "type": "select",
        "messageKey": "KEY_HOURS_MINUTES_SEPARATOR",
        "label": "Hours and Minutes Separator",
        "defaultValue": "0",
        "options": [
          { "label": "Colon :", "value": "0" },
          { "label": "Dot .",   "value": "1" }
        ]
      },
      {
        "type": "select",
        "messageKey": "KEY_DATE_FORMAT",
        "label": "Date Format",
        "defaultValue": "0",
        "options": [
          { "label": "Month Day Year", "value": "0" },
          { "label": "Day Month Year", "value": "1" },
          { "label": "YYYY-MM-DD",     "value": "2" }
        ]
      },
      {
        "type": "select",
        "messageKey": "KEY_LANGUAGE",
        "label": "Language",
        "defaultValue": "255",
        "options": [
          { "label": "Default",     "value": "255" },
          { "label": "Català",      "value": "5" },
          { "label": "Italiano",    "value": "1" },
          { "label": "Melayu",      "value": "6" },
          { "label": "Nederlandse", "value": "3" },
          { "label": "Norsk",       "value": "4" },
          { "label": "Svenska",     "value": "0" },
          { "label": "Русский",     "value": "2" },
          { "label": "Polskie",     "value": "7" }
        ]
      }
    ]
  },
  {
    "type": "section",
    "items": [
      { "type": "heading", "defaultValue": "Weather" },
      {
        "type": "select",
        "messageKey": "KEY_TEMPERATURE_FORMAT",
        "label": "Temperature",
        "defaultValue": "0",
        "options": [
          { "label": "Fahrenheit", "value": "0" },
          { "label": "Celsius",    "value": "1" }
        ]
      }
    ]
  },
  {
    "type": "section",
    "items": [
      { "type": "heading", "defaultValue": "Alerts" },
      {
        "type": "select",
        "messageKey": "KEY_BLUETOOTH_ALERT",
        "label": "Bluetooth Alert",
        "defaultValue": "0",
        "options": [
          { "label": "Disabled", "value": "0" },
          { "label": "Silent",   "value": "1" },
          { "label": "Weak",     "value": "2" },
          { "label": "Normal",   "value": "3" },
          { "label": "Strong",   "value": "4" },
          { "label": "Double",   "value": "5" }
        ]
      }
    ]
  },
  {
    "type": "section",
    "items": [
      { "type": "heading", "defaultValue": "Sydney Trains" },
      {
        "type": "input",
        "messageKey": "KEY_TFNSW_API_KEY",
        "label": "TfNSW API Key",
        "defaultValue": "",
        "description": "Free key from opendata.transport.nsw.gov.au. Leave blank to show the day of week.",
        "attributes": { "placeholder": "apikey", "type": "text" }
      },
      {
        "type": "input",
        "messageKey": "KEY_HOME_STATION_NAME",
        "label": "Home Station",
        "defaultValue": "",
        "description": "Type a station name (e.g. Gordon) or a stop ID.",
        "attributes": { "placeholder": "e.g. Gordon", "type": "text" }
      },
      {
        "type": "input",
        "messageKey": "KEY_WORK_STATION_NAME",
        "label": "Work Station",
        "defaultValue": "",
        "attributes": { "placeholder": "e.g. Wynyard", "type": "text" }
      },
      {
        "type": "select",
        "messageKey": "KEY_DIRECTION_MODE",
        "label": "Direction",
        "defaultValue": "0",
        "options": [
          { "label": "By time of day", "value": "0" },
          { "label": "Alternate each refresh", "value": "1" }
        ]
      },
      {
        "type": "slider",
        "messageKey": "KEY_CUTOFF_HOUR",
        "label": "Switch to homeward after (hour)",
        "description": "Used in 'By time of day' mode.",
        "defaultValue": 12,
        "min": 0,
        "max": 23,
        "step": 1
      },
      {
        "type": "toggle",
        "messageKey": "KEY_FASTEST_MARKER",
        "label": "Mark fastest train with *",
        "defaultValue": true
      },
      {
        "type": "slider",
        "messageKey": "KEY_PEAK1_START",
        "label": "Morning peak start (hour)",
        "defaultValue": 7,
        "min": 0,
        "max": 23,
        "step": 1
      },
      {
        "type": "slider",
        "messageKey": "KEY_PEAK1_END",
        "label": "Morning peak end (hour)",
        "defaultValue": 9,
        "min": 0,
        "max": 23,
        "step": 1
      },
      {
        "type": "slider",
        "messageKey": "KEY_PEAK2_START",
        "label": "Evening peak start (hour)",
        "defaultValue": 16,
        "min": 0,
        "max": 23,
        "step": 1
      },
      {
        "type": "slider",
        "messageKey": "KEY_PEAK2_END",
        "label": "Evening peak end (hour)",
        "defaultValue": 19,
        "min": 0,
        "max": 23,
        "step": 1
      },
      {
        "type": "select",
        "messageKey": "KEY_PEAK_INTERVAL",
        "label": "Peak refresh (minutes)",
        "defaultValue": "5",
        "options": [
          { "label": "3", "value": "3" },
          { "label": "5", "value": "5" },
          { "label": "10", "value": "10" },
          { "label": "15", "value": "15" }
        ]
      },
      {
        "type": "select",
        "messageKey": "KEY_OFFPEAK_INTERVAL",
        "label": "Off-peak refresh (minutes)",
        "defaultValue": "15",
        "options": [
          { "label": "15", "value": "15" },
          { "label": "30", "value": "30" },
          { "label": "60", "value": "60" }
        ]
      }
    ]
  },
  {
    "type": "section",
    "items": [
      { "type": "heading", "defaultValue": "Claude Usage (Pebble Time 2)" },
      {
        "type": "input",
        "messageKey": "KEY_CLAUDE_TOKEN",
        "label": "Claude OAuth Token",
        "defaultValue": "",
        "description": "From ~/.claude/.credentials.json (claudeAiOauth.accessToken). Read only on your phone to show your /usage limits; never sent to the watch. Leave blank to hide the bars. Note: this token expires periodically and must be re-pasted.",
        "attributes": { "placeholder": "sk-ant-oat...", "type": "text" }
      },
      {
        "type": "select",
        "messageKey": "KEY_USAGE_BAND_MODE",
        "label": "Band display",
        "defaultValue": "0",
        "options": [
          { "label": "Smart (bars when active)", "value": "0" },
          { "label": "Always show bars",         "value": "1" },
          { "label": "Always alternate with date","value": "2" }
        ]
      },
      {
        "type": "select",
        "messageKey": "KEY_USAGE_DISPLAY_MODE",
        "label": "Bar style",
        "defaultValue": "0",
        "options": [
          { "label": "Progress bars",     "value": "0" },
          { "label": "Raw percentages",   "value": "1" }
        ]
      },
      {
        "type": "slider",
        "messageKey": "KEY_USAGE_PACE_OFFSET",
        "label": "Amber when used% exceeds elapsed% by N",
        "defaultValue": 5,
        "min": 0,
        "max": 30,
        "step": 1
      },
      {
        "type": "slider",
        "messageKey": "KEY_USAGE_ABS_WARN",
        "label": "Only warn if used% is at least N (0=always)",
        "defaultValue": 10,
        "min": 0,
        "max": 50,
        "step": 5
      },
      {
        "type": "color",
        "messageKey": "KEY_USAGE_COLOR_GOOD",
        "label": "Bar colour: on-pace",
        "defaultValue": "00ff00",
        "sunlight": false,
        "capabilities": ["COLOR"]
      },
      {
        "type": "select",
        "messageKey": "KEY_USAGE_COLOR_GOOD",
        "label": "Bar colour: on-pace",
        "defaultValue": "16777215",
        "options": [
          { "label": "White",      "value": "16777215" },
          { "label": "Light gray", "value": "11184810" },
          { "label": "Dark gray",  "value": "5592405"  }
        ],
        "capabilities": ["BW"]
      },
      {
        "type": "color",
        "messageKey": "KEY_USAGE_COLOR_OVER",
        "label": "Bar colour: over-pace",
        "defaultValue": "ffaa00",
        "sunlight": false,
        "capabilities": ["COLOR"]
      },
      {
        "type": "select",
        "messageKey": "KEY_USAGE_COLOR_OVER",
        "label": "Bar colour: over-pace",
        "defaultValue": "11184810",
        "options": [
          { "label": "White",      "value": "16777215" },
          { "label": "Light gray", "value": "11184810" },
          { "label": "Dark gray",  "value": "5592405"  }
        ],
        "capabilities": ["BW"]
      },
      {
        "type": "color",
        "messageKey": "KEY_USAGE_COLOR_CRIT",
        "label": "Bar colour: critical",
        "defaultValue": "ff0000",
        "sunlight": false,
        "capabilities": ["COLOR"]
      },
      {
        "type": "select",
        "messageKey": "KEY_USAGE_COLOR_CRIT",
        "label": "Bar colour: critical",
        "defaultValue": "5592405",
        "options": [
          { "label": "White",      "value": "16777215" },
          { "label": "Light gray", "value": "11184810" },
          { "label": "Dark gray",  "value": "5592405"  }
        ],
        "capabilities": ["BW"]
      }
    ]
  },
  {
    "type": "section",
    "items": [
      { "type": "heading", "defaultValue": "Colors" },
      {
        "type": "color",
        "messageKey": "KEY_TEXT_COLOR",
        "label": "Text Color",
        "defaultValue": "ffffff",
        "sunlight": false,
        "capabilities": ["COLOR"]
      },
      {
        "type": "select",
        "messageKey": "KEY_TEXT_COLOR",
        "label": "Text Color",
        "defaultValue": "16777215",
        "options": [
          { "label": "White", "value": "16777215" },
          { "label": "Black", "value": "0" }
        ],
        "capabilities": ["BW"]
      },
      {
        "type": "color",
        "messageKey": "KEY_BG_COLOR",
        "label": "Background Color",
        "defaultValue": "000000",
        "sunlight": false,
        "capabilities": ["COLOR"]
      },
      {
        "type": "select",
        "messageKey": "KEY_BG_COLOR",
        "label": "Background Color",
        "defaultValue": "0",
        "options": [
          { "label": "Black", "value": "0" },
          { "label": "White", "value": "16777215" }
        ],
        "capabilities": ["BW"]
      }
    ]
  },
  {
    "type": "submit",
    "defaultValue": "Save Settings"
  }
]
